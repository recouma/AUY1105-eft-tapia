{
  "resource_changes": [
    {
      "address": "module.vpc.aws_security_group.ec2",
      "type": "aws_security_group",
      "change": {
        "after": {
          "ingress": [
            {
              "from_port": 22,
              "to_port": 22,
              "protocol": "tcp",
              "cidr_blocks": ["10.1.0.0/16"]
            }
          ]
        }
      }
    },
    {
      "address": "module.ec2.aws_instance.main",
      "type": "aws_instance",
      "change": {
        "after": {
          "instance_type": "t2.micro",
          "tags": {
            "Name": "AUY1105-eft-ec2",
            "Project": "AUY1105-eft",
            "Environment": "dev"
          },
          "root_block_device": [
            {
              "encrypted": true,
              "volume_type": "gp3"
            }
          ]
        }
      }
    }
  ]
}
